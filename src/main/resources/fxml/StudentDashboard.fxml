<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.est.attendance.controllers.DashboardController"
            style="-fx-background-color: #f5f5f5;">
    
    <!-- Top Navigation Bar -->
    <top>
        <HBox spacing="10" style="-fx-background-color: linear-gradient(90deg, #667eea 0%, #764ba2 100%); -fx-padding: 15; -fx-alignment: center-left;">
            <Label text="Dashboard" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="welcomeLabel" 
                   text="Welcome, User" 
                   style="-fx-font-size: 14; -fx-text-fill: white;"/>
            <Button text="Logout" onAction="#handleLogout"
                    style="-fx-padding: 8 15; -fx-background-color: white; -fx-text-fill: #667eea; -fx-font-weight: bold; -fx-cursor: hand;"/>
        </HBox>
    </top>
    
    <!-- Side Navigation -->
    <left>
        <VBox spacing="10" style="-fx-background-color: white; -fx-padding: 20; -fx-border-right: 1 solid #e0e0e0;" minWidth="200">
            <Label text="Navigation" style="-fx-font-size: 14; -fx-font-weight: bold;"/>
            <Button text="Dashboard" style="-fx-padding: 10; -fx-font-size: 12; -fx-background-color: #f0f0f0; -fx-cursor: hand; -fx-alignment: center-left;" maxWidth="Infinity"/>
            <Button text="My Courses" onAction="#handleViewAttendance" 
                    style="-fx-padding: 10; -fx-font-size: 12; -fx-background-color: white; -fx-cursor: hand; -fx-alignment: center-left;" maxWidth="Infinity"/>
            <Button text="Attendance" onAction="#handleViewAttendance" 
                    style="-fx-padding: 10; -fx-font-size: 12; -fx-background-color: white; -fx-cursor: hand; -fx-alignment: center-left;" maxWidth="Infinity"/>
            <Button text="Profile" onAction="#handleViewProfile" 
                    style="-fx-padding: 10; -fx-font-size: 12; -fx-background-color: white; -fx-cursor: hand; -fx-alignment: center-left;" maxWidth="Infinity"/>
            <Region VBox.vgrow="ALWAYS"/>
        </VBox>
    </left>
    
    <!-- Main Content -->
    <center>
        <VBox spacing="20" style="-fx-padding: 20;">
            
            <!-- Welcome Card -->
            <VBox spacing="10" style="-fx-border-radius: 10; -fx-background-color: white; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 2);">
                <Label text="Welcome to your Dashboard" style="-fx-font-size: 18; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                <Label text="Track your attendance and manage your courses" style="-fx-font-size: 12; -fx-text-fill: #666;"/>
            </VBox>
            
            <!-- Courses Section -->
            <VBox spacing="10">
                <Label text="My Courses" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                
                <ListView fx:id="coursesListView" 
                          style="-fx-font-size: 12; -fx-padding: 10; -fx-control-inner-background: white;"
                          prefHeight="250"/>
            </VBox>
            
            <!-- Quick Actions -->
            <HBox spacing="15">
                <Button text="View Course Details" onAction="#handleCourseDetails"
                        style="-fx-font-size: 12; -fx-padding: 10 20; -fx-background-color: linear-gradient(135deg, #667eea 0%, #764ba2 100%); -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>
                <Button text="View Attendance Report" onAction="#handleViewAttendance"
                        style="-fx-font-size: 12; -fx-padding: 10 20; -fx-background-color: #28a745; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>
            </HBox>
            
            <Region VBox.vgrow="ALWAYS"/>
        </VBox>
    </center>
</BorderPane>
