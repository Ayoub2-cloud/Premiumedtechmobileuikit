<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.est.attendance.controllers.CourseDetailsController"
            style="-fx-background-color: #f5f5f5;">
    
    <!-- Top Bar -->
    <top>
        <HBox spacing="10" style="-fx-background-color: linear-gradient(90deg, #667eea 0%, #764ba2 100%); -fx-padding: 15; -fx-alignment: center-left;">
            <Button text="← Back" onAction="#handleBack"
                    style="-fx-padding: 8 15; -fx-background-color: white; -fx-text-fill: #667eea; -fx-font-weight: bold; -fx-cursor: hand;"/>
            <Label text="Course Details" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Region HBox.hgrow="ALWAYS"/>
        </HBox>
    </top>
    
    <!-- Main Content -->
    <center>
        <VBox spacing="20" style="-fx-padding: 20;">
            
            <!-- Course Info Card -->
            <VBox spacing="15" style="-fx-border-radius: 10; -fx-background-color: white; -fx-padding: 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 2);">
                
                <Label fx:id="courseNameLabel" 
                       text="Java Programming" 
                       style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #667eea;"/>
                
                <Separator/>
                
                <!-- Course Information Grid -->
                <GridPane hgap="20" vgap="15">
                    <Label text="Instructor:" style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #333;" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <Label fx:id="instructorLabel" 
                           text="Dr. Mohammed Bennani" 
                           style="-fx-font-size: 12; -fx-text-fill: #666;" GridPane.columnIndex="1" GridPane.rowIndex="0"/>
                    
                    <Label text="Schedule:" style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #333;" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <Label fx:id="scheduleLabel" 
                           text="Monday 10:00-12:00 | Room 101" 
                           style="-fx-font-size: 12; -fx-text-fill: #666;" GridPane.columnIndex="1" GridPane.rowIndex="1"/>
                </GridPane>
            </VBox>
            
            <!-- Attendance Statistics -->
            <VBox spacing="15" style="-fx-border-radius: 10; -fx-background-color: white; -fx-padding: 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 2);">
                
                <Label text="Attendance Statistics" style="-fx-font-size: 16; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                
                <VBox spacing="10">
                    <Label text="Attendance Rate:" style="-fx-font-size: 12; -fx-text-fill: #666;"/>
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <ProgressBar fx:id="attendanceProgressBar" prefWidth="250"/>
                        <Label fx:id="attendancePercentageLabel" 
                               text="85%" 
                               style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: #28a745;"/>
                    </HBox>
                </VBox>
            </VBox>
            
            <Region VBox.vgrow="ALWAYS"/>
        </VBox>
    </center>
</BorderPane>
