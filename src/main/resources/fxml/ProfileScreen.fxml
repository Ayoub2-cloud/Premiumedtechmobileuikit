<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.est.attendance.controllers.ProfileController"
            style="-fx-background-color: #f5f5f5;">
    
    <!-- Top Bar -->
    <top>
        <HBox spacing="10" style="-fx-background-color: linear-gradient(90deg, #667eea 0%, #764ba2 100%); -fx-padding: 15; -fx-alignment: center-left;">
            <Button text="← Back" onAction="#handleBack"
                    style="-fx-padding: 8 15; -fx-background-color: white; -fx-text-fill: #667eea; -fx-font-weight: bold; -fx-cursor: hand;"/>
            <Label text="My Profile" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="Logout" onAction="#handleLogout"
                    style="-fx-padding: 8 15; -fx-background-color: white; -fx-text-fill: #667eea; -fx-font-weight: bold; -fx-cursor: hand;"/>
        </HBox>
    </top>
    
    <!-- Main Content -->
    <center>
        <VBox spacing="20" style="-fx-padding: 40;">
            
            <!-- Profile Card -->
            <VBox spacing="20" style="-fx-border-radius: 10; -fx-background-color: white; -fx-padding: 30; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 2);" maxWidth="500" alignment="TOP_CENTER">
                
                <!-- Profile Header -->
                <VBox alignment="CENTER" spacing="10">
                    <Circle radius="50" fill="linear-gradient(135deg, #667eea 0%, #764ba2 100%)" />
                    <Label fx:id="nameLabel" 
                           text="Ahmed Mohammed" 
                           style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: #333;"/>
                </VBox>
                
                <Separator/>
                
                <!-- Profile Information -->
                <GridPane hgap="15" vgap="15">
                    <Label text="Email:" style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #333;" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                    <TextField fx:id="emailField" editable="false" style="-fx-font-size: 12;" GridPane.columnIndex="1" GridPane.rowIndex="0" maxWidth="300"/>
                    
                    <Label text="Department:" style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #333;" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                    <TextField fx:id="departmentField" editable="false" style="-fx-font-size: 12;" GridPane.columnIndex="1" GridPane.rowIndex="1" maxWidth="300"/>
                    
                    <Label text="Semester:" style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #333;" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                    <TextField fx:id="semesterField" editable="false" style="-fx-font-size: 12;" GridPane.columnIndex="1" GridPane.rowIndex="2" maxWidth="300"/>
                    
                    <Label text="GPA:" style="-fx-font-size: 12; -fx-font-weight: bold; -fx-text-fill: #333;" GridPane.columnIndex="0" GridPane.rowIndex="3"/>
                    <TextField fx:id="gpaField" editable="false" style="-fx-font-size: 12;" GridPane.columnIndex="1" GridPane.rowIndex="3" maxWidth="300"/>
                </GridPane>
            </VBox>
            
            <Region VBox.vgrow="ALWAYS"/>
        </VBox>
    </center>
</BorderPane>
