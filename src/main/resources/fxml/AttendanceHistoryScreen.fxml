<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.est.attendance.controllers.AttendanceHistoryController"
            style="-fx-background-color: #f5f5f5;">
    
    <!-- Top Bar -->
    <top>
        <HBox spacing="10" style="-fx-background-color: linear-gradient(90deg, #667eea 0%, #764ba2 100%); -fx-padding: 15; -fx-alignment: center-left;">
            <Button text="← Back" onAction="#handleBack"
                    style="-fx-padding: 8 15; -fx-background-color: white; -fx-text-fill: #667eea; -fx-font-weight: bold; -fx-cursor: hand;"/>
            <Label text="Attendance History" style="-fx-font-size: 20; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="attendancePercentageLabel" 
                   text="Attendance: 85%" 
                   style="-fx-font-size: 14; -fx-text-fill: white; -fx-font-weight: bold;"/>
        </HBox>
    </top>
    
    <!-- Main Content -->
    <center>
        <VBox spacing="20" style="-fx-padding: 20;">
            
            <!-- Summary Cards -->
            <HBox spacing="15">
                <VBox spacing="5" style="-fx-border-radius: 10; -fx-background-color: white; -fx-padding: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 2);" HBox.hgrow="ALWAYS">
                    <Label text="Total Classes" style="-fx-font-size: 12; -fx-text-fill: #666;"/>
                    <Label text="25" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #667eea;"/>
                </VBox>
                <VBox spacing="5" style="-fx-border-radius: 10; -fx-background-color: white; -fx-padding: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 2);" HBox.hgrow="ALWAYS">
                    <Label text="Present" style="-fx-font-size: 12; -fx-text-fill: #666;"/>
                    <Label text="21" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #28a745;"/>
                </VBox>
                <VBox spacing="5" style="-fx-border-radius: 10; -fx-background-color: white; -fx-padding: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 5, 0, 0, 2);" HBox.hgrow="ALWAYS">
                    <Label text="Absent" style="-fx-font-size: 12; -fx-text-fill: #666;"/>
                    <Label text="4" style="-fx-font-size: 24; -fx-font-weight: bold; -fx-text-fill: #dc3545;"/>
                </VBox>
            </HBox>
            
            <!-- Attendance Table -->
            <VBox spacing="10">
                <Label text="Attendance Records" style="-fx-font-size: 14; -fx-font-weight: bold;"/>
                <TableView fx:id="attendanceTable" style="-fx-font-size: 12; -fx-control-inner-background: white;" prefHeight="350">
                    <columns>
                        <TableColumn fx:id="dateColumn" text="Date" prefWidth="150"/>
                        <TableColumn fx:id="statusColumn" text="Status" prefWidth="150"/>
                    </columns>
                </TableView>
            </VBox>
            
            <Region VBox.vgrow="ALWAYS"/>
        </VBox>
    </center>
</BorderPane>
